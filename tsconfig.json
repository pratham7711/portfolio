{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "/tmp/final/types/**/*.ts",
    "/tmp/nd5/types/**/*.ts",
    "/tmp/nextdev/types/**/*.ts",
    "/tmp/nextdev2/types/**/*.ts",
    "/tmp/nextdev3/types/**/*.ts",
    "/tmp/nextdev4/types/**/*.ts",
    "/tmp/sota/types/**/*.ts",
    "/tmp/v3/types/**/*.ts",
    "next-env.d.ts",
    "tmp/final-verify/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "legacy",
    "dist"
  ]
}
